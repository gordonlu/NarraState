# NarraState Configuration
# Copy this file to .env and fill in your values.

# LLM Provider (OpenAI-compatible)
NARRASTATE_BASE_URL=https://api.openai.com/v1
NARRASTATE_MODEL=gpt-4o-mini
NARRASTATE_API_KEY=

# Server
NARRASTATE_HOST=127.0.0.1
NARRASTATE_PORT=3000

# Storage
DATABASE_URL=sqlite://data/narrastate.db?mode=rwc

# Logging
RUST_LOG=info,narrastate=debug
