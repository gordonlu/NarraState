# Optional NarraState environment overrides.
# Most users should run ./start.sh (or .\start.ps1) and configure providers in
# the Web UI. The local startup scripts do not automatically load this file.
# Docker Compose reads a root .env automatically; local shells require exports.

# Text provider (OpenAI-compatible). Prefer the Web UI, which stores the key in
# data/provider.env without returning it to the browser.
NARRASTATE_BASE_URL=https://api.openai.com/v1
NARRASTATE_MODEL=gpt-4o-mini
NARRASTATE_GENERATION_TIMEOUT_SECS=180
NARRASTATE_GENERATION_MAX_TOKENS=65536
NARRASTATE_API_KEY=

# Server
NARRASTATE_HOST=127.0.0.1
NARRASTATE_PORT=3000

# Storage
DATABASE_URL=sqlite://data/narrastate.db?mode=rwc

# Logging
RUST_LOG=info,narrastate=debug
